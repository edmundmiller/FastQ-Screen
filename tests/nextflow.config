// Test-specific Nextflow configuration
params {
    // Limit resources for testing
    max_cpus   = 2
    max_memory = '2.GB'
    max_time   = '1.h'
}

// Disable all container engines for local testing
singularity.enabled = false
docker.enabled = false
podman.enabled = false
conda.enabled = false

// Global process configuration for tests
process {
    cpus = { check_max( 1, 'cpus' ) }
    memory = { check_max( 1.GB * task.attempt, 'memory' ) }
    time = { check_max( 10.min * task.attempt, 'time' ) }
    
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'terminate' }
    maxRetries = 1
    maxErrors = '-1'
    
    // Use local execution for testing
    container = null
}