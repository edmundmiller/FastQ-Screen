// Test-specific Nextflow configuration
params {
    // Limit resources for testing
    max_cpus   = 2
    max_memory = '2.GB'
    max_time   = '1.h'
    
    // Enable singularity for container tests
    singularity_pull_docker_container = false
    
    // Disable conda and docker for testing
    conda.enabled = false
    docker.enabled = false
}

singularity {
    enabled = true
    autoMounts = true
}

// Global process configuration for tests
process {
    cpus = { check_max( 1, 'cpus' ) }
    memory = { check_max( 1.GB * task.attempt, 'memory' ) }
    time = { check_max( 10.min * task.attempt, 'time' ) }
    
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'terminate' }
    maxRetries = 1
    maxErrors = '-1'
}